<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="96dp"
    android:layout_height="96dp"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="?attr/selectableItemBackgroundBorderless">

        <!-- 文件夹图标（显示4个小图标） -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFolder"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardBackgroundColor="@color/surface_variant"
            app:cardCornerRadius="@dimen/app_icon_corner"
            app:cardElevation="0dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:columnCount="2"
                android:rowCount="2"
                android:padding="6dp">

                <ImageView
                    android:id="@+id/folderIcon1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:scaleType="centerCrop"
                    android:padding="2dp"
                    android:contentDescription="应用1" />

                <ImageView
                    android:id="@+id/folderIcon2"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:scaleType="centerCrop"
                    android:padding="2dp"
                    android:contentDescription="应用2" />

                <ImageView
                    android:id="@+id/folderIcon3"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:scaleType="centerCrop"
                    android:padding="2dp"
                    android:contentDescription="应用3" />

                <ImageView
                    android:id="@+id/folderIcon4"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_columnWeight="1"
                    android:layout_rowWeight="1"
                    android:scaleType="centerCrop"
                    android:padding="2dp"
                    android:contentDescription="应用4" />

            </GridLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- 文件夹名称 -->
        <TextView
            android:id="@+id/tvFolderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="@dimen/app_label_size"
            android:textColor="@color/on_surface"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:maxWidth="72dp" />

    </LinearLayout>

</FrameLayout>
