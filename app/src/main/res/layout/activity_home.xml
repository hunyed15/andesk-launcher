<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 顶部区域：时钟和天气 -->
    <LinearLayout
        android:id="@+id/topArea"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 时钟 -->
        <TextView
            android:id="@+id/tvTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14:32"
            android:textSize="96sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-light" />

        <!-- 日期 -->
        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2026年06月13日 星期五"
            android:textSize="18sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp" />

        <!-- 天气卡片 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardWeather"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <!-- 天气图标 -->
                <ImageView
                    android:id="@+id/ivWeatherIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_weather_sunny"
                    android:contentDescription="天气图标" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <!-- 温度 -->
                    <TextView
                        android:id="@+id/tvWeatherTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="28°C"
                        android:textSize="32sp"
                        android:textColor="@color/text_primary"
                        android:fontFamily="sans-serif-medium" />

                    <!-- 天气描述 -->
                    <TextView
                        android:id="@+id/tvWeatherText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="晴"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <!-- 城市 -->
                <TextView
                    android:id="@+id/tvWeatherCity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="上海"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- 中间区域：应用网格 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvApps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="24dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topArea"
        app:layout_constraintBottom_toTopOf="@id/dockBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 底部Dock栏 -->
    <LinearLayout
        android:id="@+id/dockBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:background="@color/surface"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Dock应用占位 -->
        <ImageView
            android:id="@+id/dockApp1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:scaleType="centerInside"
            android:contentDescription="Dock应用1" />

        <ImageView
            android:id="@+id/dockApp2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:scaleType="centerInside"
            android:contentDescription="Dock应用2" />

        <ImageView
            android:id="@+id/dockApp3"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:scaleType="centerInside"
            android:contentDescription="Dock应用3" />

        <ImageView
            android:id="@+id/dockApp4"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:scaleType="centerInside"
            android:contentDescription="Dock应用4" />

        <!-- 分隔线 -->
        <View
            android:layout_width="1dp"
            android:layout_height="32dp"
            android:layout_marginHorizontal="8dp"
            android:background="@color/text_hint" />

        <!-- 所有应用按钮 -->
        <ImageView
            android:id="@+id/btnAllApps"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_apps_grid"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="所有应用" />

        <!-- 设置按钮 -->
        <ImageView
            android:id="@+id/btnSettings"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_settings"
            android:scaleType="centerInside"
            android:padding="8dp"
            android:contentDescription="设置" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
